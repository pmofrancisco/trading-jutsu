// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ForexCurrencyPair {
  id      Int    @id @default(autoincrement())
  baseCurrency   String
  quoteCurrency  String
  quotes  ForexQuote[]
}

model ForexQuote {
  id      Int    @id @default(autoincrement())
  open    Float
  high    Float
  low     Float
  close   Float
  timestamp   DateTime
  pairId  Int
  pair    ForexCurrencyPair @relation(fields: [pairId], references: [id])
}

model PseSector {
  id    Int    @id @default(autoincrement())
  name  String
}
